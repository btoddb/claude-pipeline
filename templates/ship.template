#!/usr/bin/env bash
#
# ship — cut a GitHub release for this repo.
#
# The @claude ship command merges the PR, checks out main, then calls this
# script. You can also run it directly from a clean main branch.
#
# Usage:
#   scripts/ship --bump-patch            # pre-release; increment X.Y.Z to X.Y.(Z+1)
#   scripts/ship --bump-minor            # pre-release; increment X.Y.Z to X.(Y+1).0
#   scripts/ship --bump-major            # pre-release; increment X.Y.Z to (X+1).0.0
#   scripts/ship --public-release --bump-minor
#                                         # full release; label: latest, title: <tag>
#   scripts/ship --dry-run --bump-patch  # print every command, change nothing
#
# Version is resolved in order:
#   1. VERSION file in repo root  (single line, e.g. "1.2.3" or "v1.2.3")
#   2. Latest git vX.Y.Z tag + selected bump
#   3. v0.1.0 if no prior semver tags exist  (a bump flag is still required)
#
set -euo pipefail

PUBLIC_RELEASE=false
DRY_RUN=false
BUMP=""
BUMP_SET=false

die() { echo "ship: $*" >&2; exit 1; }

set_bump() {
  if $BUMP_SET; then
    echo "ship: choose only one bump flag" >&2
    exit 2
  fi
  BUMP="$1"
  BUMP_SET=true
}

while [ $# -gt 0 ]; do
  case "$1" in
    --public-release) PUBLIC_RELEASE=true; shift ;;
    --bump-patch)     set_bump patch;      shift ;;
    --bump-minor)     set_bump minor;      shift ;;
    --bump-major)     set_bump major;      shift ;;
    --dry-run)        DRY_RUN=true;        shift ;;
    -h|--help)        sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "ship: unknown argument '$1' (try --help)" >&2; exit 2 ;;
  esac
done

if ! $BUMP_SET; then
  die "choose a version bump: --bump-patch, --bump-minor, or --bump-major"
fi

run() {
  if $DRY_RUN; then echo "DRY-RUN: $*"; else echo "+ $*"; "$@"; fi
}

# --- Preconditions -----------------------------------------------------------
branch="$(git rev-parse --abbrev-ref HEAD)"
[ "$branch" = "main" ] || die "must be on 'main' (currently on '$branch')."
[ -z "$(git status --porcelain)" ] || die "working tree is not clean — commit or stash first."

# --- Version resolution -------------------------------------------------------
if [ -f VERSION ]; then
  raw="$(tr -d '[:space:]' < VERSION)"
  version="v${raw#v}"
else
  latest="$(git tag --list 'v*' --sort=-v:refname \
    | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || true)"
  if [ -z "$latest" ]; then
    version="v0.1.0"
  else
    IFS='.' read -r vmajor vminor vpatch <<< "${latest#v}"
    case "$BUMP" in
      patch) version="v${vmajor}.${vminor}.$((vpatch + 1))" ;;
      minor) version="v${vmajor}.$((vminor + 1)).0" ;;
      major) version="v$((vmajor + 1)).0.0" ;;
    esac
  fi
fi

if git rev-parse -q --verify "refs/tags/$version" >/dev/null 2>&1; then
  die "tag '$version' already exists — bump the VERSION file or the latest tag before shipping."
fi

# --- Release ------------------------------------------------------------------
if $PUBLIC_RELEASE; then
  title="$version"
  echo "Cutting public release $version:"
  run git tag -a "$version" -m "Release $version"
  run git push origin "$version"
  run gh release create "$version" \
    --title "$title" \
    --latest \
    --generate-notes
else
  title="${version}-beta"
  echo "Cutting pre-release $version (title: '$title'):"
  run git tag -a "$version" -m "Pre-release $version"
  run git push origin "$version"
  run gh release create "$version" \
    --title "$title" \
    --prerelease \
    --generate-notes
fi

echo "Done. Release '$title' is live."
